#!/bin/bash
# Pre-commit: verify chezmoi state is in sync

if command -v chezmoi >/dev/null 2>&1; then
  if ! chezmoi verify --source ~/.dotfiles 2>/dev/null; then
    echo ""
    echo "⚠  chezmoi drift detected — some managed files differ from source."
    echo "   Run 'chezmoi diff' to inspect, 'chezmoi re-add <file>' to sync."
    echo ""
    echo "   Proceeding with commit anyway."
    echo ""
  fi
fi
