#!/usr/bin/env bash
set -euo pipefail

# swift: {{ include "dot_config/sketchybar/bin/calendar_events.swift" | sha256sum }}
# plist: {{ include "dot_config/sketchybar/bin/calendar_events.plist" | sha256sum }}

DIR="$HOME/.config/sketchybar/bin"
SRC="$DIR/calendar_events.swift"
PLIST="$DIR/calendar_events.plist"
APP="$DIR/calendar_events.app"

command -v swiftc >/dev/null 2>&1 || {
	printf 'swiftc not found; skipping sketchybar helper build\n' >&2
	exit 0
}

if [ -f "$SRC" ]; then
	rm -f "$DIR/calendar_events"
	mkdir -p "$APP/Contents/MacOS"
	cp "$PLIST" "$APP/Contents/Info.plist"
	swiftc "$SRC" -O -o "$APP/Contents/MacOS/calendar_events" \
		-framework EventKit -framework Foundation
	codesign --force --sign - "$APP" >/dev/null 2>&1 || true
fi
