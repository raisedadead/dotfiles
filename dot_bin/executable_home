# File name: home
# Two-repo chezmoi wrapper (public + private)
#-----------------------------------------------------------

set -uo pipefail

PUB="$HOME/.dotfiles"
PRIV="$HOME/.dotfiles-private"

# Colors
DIM=$'\e[0;90m'; GRN=$'\e[0;32m'; RED=$'\e[0;31m'; YLW=$'\e[0;33m'
CYN=$'\e[0;36m'; BLD=$'\e[1m'; RST=$'\e[0m'

p()  { printf "${DIM}dotfiles Â·${RST} %s\n" "$1"; }
ok() { printf "${GRN}dotfiles Â·${RST} %s\n" "$1"; }

has_priv() { [[ -d "$PRIV" ]]; }

# Run a chezmoi command against both repos
both() {
  chezmoi "$@"
  has_priv && chezmoi --source "$PRIV" "$@"
}

cmd_help() {
  echo ""
  printf "  ${BLD}home check${RST}               ${DIM}status + what to do next${RST}\n"
  printf "  ${BLD}home apply${RST}               ${DIM}apply both repos to ~${RST}\n"
  printf "  ${BLD}home pull${RST}                ${DIM}pull + apply both repos${RST}\n"
  printf "  ${BLD}home push${RST}                ${DIM}push both repos${RST}\n"
  printf "  ${BLD}home status${RST}              ${DIM}git status both repos${RST}\n"
  printf "  ${BLD}home diff${RST}                ${DIM}diff both repos${RST}\n"
  printf "  ${BLD}home managed${RST}             ${DIM}list all managed files${RST}\n"
  printf "  ${BLD}home verify${RST}              ${DIM}verify sync state${RST}\n"
  printf "  ${BLD}home init${RST}                ${DIM}first-time setup${RST}\n"
  echo ""
  printf "  ${DIM}Everything else passes through to chezmoi:${RST}\n"
  printf "  ${DIM}home re-add, home edit, home doctor, etc.${RST}\n"
  echo ""
}

cmd_init() {
  if ! has_priv; then
    p "cloning private repo..."
    git clone git@github.com:raisedadead/dotfiles-private.git "$PRIV" || {
      printf "${YLW}dotfiles Â·${RST} clone failed â€” is SSH configured?\n"
      printf "           run ${BLD}home init${RST} after setting up SSH\n"
      exit 1
    }
  else
    p "private repo exists"
  fi
  p "applying public..."
  chezmoi apply
  p "applying private..."
  chezmoi --source "$PRIV" apply
  ok "done"
}

cmd_apply() {
  p "applying public..."
  chezmoi apply
  ok "public applied"
  if has_priv; then
    p "applying private..."
    chezmoi --source "$PRIV" apply
    ok "private applied"
  fi
}

cmd_pull() {
  p "pulling public..."
  chezmoi update
  ok "public updated"
  if has_priv; then
    p "pulling private..."
    git -C "$PRIV" pull --rebase
    chezmoi --source "$PRIV" apply
    ok "private updated"
  fi
}

cmd_push() {
  local br
  br=$(git -C "$PUB" branch --show-current)
  p "pushing public ($br)..."
  git -C "$PUB" push origin "$br"
  ok "public pushed"
  if has_priv; then
    br=$(git -C "$PRIV" branch --show-current)
    p "pushing private ($br)..."
    git -C "$PRIV" push origin "$br"
    ok "private pushed"
  fi
}

cmd_status() {
  printf "${DIM}dotfiles Â·${RST} ${BLD}public${RST}\n"
  git -C "$PUB" status --short
  if has_priv; then
    echo ""
    printf "${DIM}dotfiles Â·${RST} ${BLD}private${RST}\n"
    git -C "$PRIV" status --short
  fi
}

cmd_diff()    { both diff; }
cmd_managed() { both managed; }

cmd_verify() {
  printf "${DIM}dotfiles Â·${RST} ${BLD}public${RST}  "
  if chezmoi verify 2>/dev/null; then
    printf "${GRN}in sync${RST}\n"
  else
    printf "${YLW}drift detected${RST} â€” run ${BLD}home diff${RST}\n"
  fi
  if has_priv; then
    printf "${DIM}dotfiles Â·${RST} ${BLD}private${RST} "
    if chezmoi --source "$PRIV" verify 2>/dev/null; then
      printf "${GRN}in sync${RST}\n"
    else
      printf "${YLW}drift detected${RST} â€” run ${BLD}home diff${RST}\n"
    fi
  fi
}

cmd_check() {
  local PUB_N PRIV_N
  PUB_N=$(chezmoi managed 2>/dev/null | wc -l | tr -d ' ')
  PRIV_N=$(chezmoi --source "$PRIV" managed 2>/dev/null | wc -l | tr -d ' ')
  printf "${BLD}dotfiles${RST} ${DIM}Â· %s public Â· %s private${RST}\n\n" "$PUB_N" "$PRIV_N"

  git -C "$PUB" fetch --quiet 2>/dev/null &
  has_priv && git -C "$PRIV" fetch --quiet 2>/dev/null &
  wait

  local ACT_PULL="" ACT_COMMIT="" ACT_APPLY="" ACT_PUSH="" HAS_ISSUES=0
  local DIR CM_SRC APPLY AHEAD BEHIND BR DIRTY DIRTY_N UNAPPLIED S

  pad() { local n=$((26 - ${#1})); printf '%*s' "$n" ''; }

  for REPO in public private; do
    if [[ "$REPO" == "public" ]]; then
      DIR="$PUB"; CM_SRC=""; APPLY="home apply"
    else
      DIR="$PRIV"; CM_SRC="--source $PRIV"; APPLY="home apply"
      if [[ ! -d "$DIR" ]]; then
        printf "  ${DIM}%-10s not cloned${RST}\n" "$REPO"
        continue
      fi
    fi

    AHEAD=0; BEHIND=0
    BR=$(git -C "$DIR" branch --show-current 2>/dev/null)
    if git -C "$DIR" rev-parse --verify "origin/$BR" &>/dev/null; then
      read -r BEHIND AHEAD < <(git -C "$DIR" rev-list --left-right --count "origin/$BR...HEAD" 2>/dev/null)
    fi

    DIRTY=$(git -C "$DIR" status --porcelain 2>/dev/null)
    DIRTY_N=0; [[ -n "$DIRTY" ]] && DIRTY_N=$(echo "$DIRTY" | wc -l | tr -d ' ')

    UNAPPLIED=$(chezmoi $CM_SRC diff --no-pager 2>&1 | grep -c '^diff' || true)

    S=""
    (( BEHIND > 0 ))    && S="${S} ${CYN}${BEHIND}â†“${RST}"
    (( AHEAD > 0 ))     && S="${S} ${YLW}${AHEAD}â†‘${RST}"
    (( DIRTY_N > 0 ))   && S="${S} ${RED}${DIRTY_N} dirty${RST}"
    (( UNAPPLIED > 0 )) && S="${S} ${YLW}${UNAPPLIED} to apply${RST}"

    if [[ -z "$S" ]]; then
      printf "  %-10s ${GRN}âś“${RST}\n" "$REPO"
    else
      HAS_ISSUES=1
      printf "  %-10s%s\n" "$REPO" "$S"
      if [[ -n "$DIRTY" ]]; then
        echo "$DIRTY" | while IFS= read -r l; do
          printf "  ${DIM}           %s${RST}\n" "$l"
        done
      fi
    fi

    (( BEHIND > 0 ))    && ACT_PULL="  ${BLD}home pull${RST}$(pad 'home pull')${DIM}pull from origin${RST}\n"
    if (( DIRTY_N > 0 )); then
      local SHORT_DIR="${DIR/#$HOME/\~}"
      ACT_COMMIT="${ACT_COMMIT}  ${DIM}(${REPO})${RST} ${BLD}cd ${SHORT_DIR} && git add -A && git commit${RST}\n"
    fi
    (( UNAPPLIED > 0 )) && ACT_APPLY="${ACT_APPLY}  ${BLD}${APPLY}${RST}$(pad "$APPLY")${DIM}apply ${UNAPPLIED} files to ~${RST}\n"
    (( AHEAD > 0 ))     && ACT_PUSH="  ${BLD}home push${RST}$(pad 'home push')${DIM}push to origin${RST}\n"
  done

  local ACTS="${ACT_PULL}${ACT_COMMIT}${ACT_APPLY}${ACT_PUSH}"
  if [[ -n "$ACTS" ]]; then
    printf "\n${DIM}next â†’${RST}\n"
    printf "%b" "$ACTS"
  elif (( HAS_ISSUES == 0 )); then
    printf "\n${GRN}all clear${RST}\n"
  fi
}

case "${1:-}" in
  check)   cmd_check ;;
  init)    cmd_init ;;
  apply)   cmd_apply ;;
  pull)    cmd_pull ;;
  push)    cmd_push ;;
  status)  cmd_status ;;
  diff)    cmd_diff ;;
  managed) cmd_managed ;;
  verify)  cmd_verify ;;
  help|"") cmd_help ;;
  *)       chezmoi "$@" ;;
esac
