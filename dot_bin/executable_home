# File name: home
# Two-repo chezmoi wrapper (public + private)
#-----------------------------------------------------------

set -uo pipefail

PUB="$HOME/.dotfiles"
PRIV="$HOME/.dotfiles-private"

# Colors
DIM=$'\e[0;90m'; GRN=$'\e[0;32m'; RED=$'\e[0;31m'; YLW=$'\e[0;33m'
CYN=$'\e[0;36m'; BLD=$'\e[1m'; RST=$'\e[0m'

p()  { printf "${DIM}dotfiles ·${RST} %s\n" "$1"; }
ok() { printf "${GRN}dotfiles ·${RST} %s\n" "$1"; }

has_priv() { [[ -d "$PRIV" ]]; }

# Run chezmoi for a named repo (public|private)
# Config template lives in public repo only — suppress stale-config warning on private
_cm() {
  local repo="$1"; shift
  if [[ "$repo" == "private" ]]; then
    chezmoi --source "$PRIV" "$@" 2> >(grep -v 'config file template' >&2)
  else
    chezmoi "$@"
  fi
}

# List repos to operate on based on REPO_SEL
_repos() {
  case "${REPO_SEL:-}" in
    public)  echo "public" ;;
    private) echo "private" ;;
    *)       echo "public"; has_priv && echo "private" ;;
  esac
}

# Parse optional repo selector: home [public|private] <command>
REPO_SEL=""
case "${1:-}" in
  public|pub)   REPO_SEL="public"; shift ;;
  private|prv)  REPO_SEL="private"; shift ;;
esac

cmd_help() {
  echo ""
  printf "  ${BLD}home check${RST}               ${DIM}show status and suggested actions${RST}\n"
  printf "  ${BLD}home re-add${RST}              ${DIM}sync edited files from ~ back to source${RST}\n"
  printf "  ${BLD}home apply${RST}               ${DIM}apply source to home dir${RST}\n"
  printf "  ${BLD}home pull${RST}                ${DIM}pull and apply both repos${RST}\n"
  printf "  ${BLD}home push${RST}                ${DIM}push both repos to origin${RST}\n"
  echo ""
  printf "  ${BLD}home status${RST}              ${DIM}show git status for both repos${RST}\n"
  printf "  ${BLD}home diff${RST}                ${DIM}show pending changes${RST}\n"
  printf "  ${BLD}home managed${RST}             ${DIM}list all managed files${RST}\n"
  printf "  ${BLD}home verify${RST}              ${DIM}check if home dir is in sync${RST}\n"
  echo ""
  printf "  ${BLD}home init${RST}                ${DIM}clone private repo and apply both${RST}\n"
  echo ""
  printf "  ${DIM}Prefix with ${RST}${BLD}public${RST}${DIM} or ${RST}${BLD}private${RST}${DIM} to target one repo:${RST}\n"
  printf "  ${DIM}e.g. home pub re-add, home prv apply${RST}\n"
  echo ""
  printf "  ${DIM}Anything else is passed through to chezmoi directly.${RST}\n"
  printf "  ${DIM}e.g. home edit, home doctor, home cd${RST}\n"
  echo ""
}

cmd_init() {
  echo ""
  if ! has_priv; then
    p "cloning private repo..."
    git clone git@github.com:raisedadead/dotfiles-private.git "$PRIV" || {
      echo ""
      printf "${YLW}dotfiles ·${RST} clone failed — is SSH configured?\n"
      printf "           run ${BLD}home init${RST} after setting up SSH\n"
      exit 1
    }
  else
    p "private repo found"
  fi
  echo ""
  p "regenerating config..."
  chezmoi init
  p "applying public repo..."
  chezmoi apply
  p "applying private repo..."
  _cm private apply
  echo ""
  ok "setup complete"
}

cmd_readd() {
  echo ""
  local first=1
  for repo in $(_repos); do
    (( first )) || echo ""
    first=0
    p "re-adding $repo repo..."
    _cm "$repo" re-add
    ok "$repo repo re-added"
  done
  echo ""
}

cmd_apply() {
  echo ""
  local first=1
  for repo in $(_repos); do
    (( first )) || echo ""
    first=0
    p "applying $repo repo..."
    _cm "$repo" apply
    ok "$repo repo applied"
  done
  echo ""
}

cmd_pull() {
  echo ""
  p "pulling public repo..."
  chezmoi update
  ok "public repo updated"
  if has_priv; then
    echo ""
    p "pulling private repo..."
    git -C "$PRIV" pull --rebase
    _cm private apply
    ok "private repo updated"
  fi
  echo ""
}

cmd_push() {
  local br
  echo ""
  br=$(git -C "$PUB" branch --show-current)
  p "pushing public repo ($br)..."
  git -C "$PUB" push origin "$br"
  ok "public repo pushed"
  if has_priv; then
    echo ""
    br=$(git -C "$PRIV" branch --show-current)
    p "pushing private repo ($br)..."
    git -C "$PRIV" push origin "$br"
    ok "private repo pushed"
  fi
  echo ""
}

cmd_status() {
  echo ""
  printf "${DIM}dotfiles ·${RST} ${BLD}public repo${RST}\n"
  git -C "$PUB" status --short
  if has_priv; then
    echo ""
    printf "${DIM}dotfiles ·${RST} ${BLD}private repo${RST}\n"
    git -C "$PRIV" status --short
  fi
  echo ""
}

cmd_diff() {
  for repo in $(_repos); do
    _cm "$repo" diff
  done
}

cmd_managed() {
  for repo in $(_repos); do
    _cm "$repo" managed
  done
}

cmd_verify() {
  echo ""
  for repo in $(_repos); do
    printf "  ${BLD}%-14s${RST}" "$repo repo"
    if _cm "$repo" verify 2>/dev/null; then
      printf "${GRN}in sync${RST}\n"
    else
      printf "${YLW}drift detected${RST} — run ${BLD}home diff${RST} or ${BLD}home re-add${RST}\n"
    fi
  done
  echo ""
}

cmd_check() {
  local PUB_N PRIV_N
  PUB_N=$(chezmoi managed 2>/dev/null | wc -l | tr -d ' ')
  PRIV_N=$(chezmoi --source "$PRIV" managed 2>/dev/null | wc -l | tr -d ' ')
  echo ""
  printf "${BLD}dotfiles${RST} ${DIM}· %s public · %s private${RST}\n\n" "$PUB_N" "$PRIV_N"

  git -C "$PUB" fetch --quiet 2>/dev/null &
  has_priv && git -C "$PRIV" fetch --quiet 2>/dev/null &
  wait

  local HAS_ISSUES=0 HAS_PULL=0 HAS_APPLY=0 HAS_READD=0 HAS_PUSH=0
  local DIR CM_SRC AHEAD BEHIND BR DIRTY DIRTY_N UNAPPLIED S SHORT_DIR

  # collect per-repo status + actions
  declare -a REPO_ACTS_pub=() REPO_ACTS_priv=()

  for REPO in public private; do
    if [[ "$REPO" == "public" ]]; then
      DIR="$PUB"; CM_SRC=""
    else
      DIR="$PRIV"; CM_SRC="--source $PRIV"
      if [[ ! -d "$DIR" ]]; then
        printf "  ${DIM}%-10s not cloned${RST}\n" "$REPO"
        continue
      fi
    fi

    SHORT_DIR="${DIR/#$HOME/\~}"
    AHEAD=0; BEHIND=0
    BR=$(git -C "$DIR" branch --show-current 2>/dev/null)
    if git -C "$DIR" rev-parse --verify "origin/$BR" &>/dev/null; then
      read -r BEHIND AHEAD < <(git -C "$DIR" rev-list --left-right --count "origin/$BR...HEAD" 2>/dev/null)
    fi

    DIRTY=$(git -C "$DIR" status --porcelain 2>/dev/null)
    DIRTY_N=0; [[ -n "$DIRTY" ]] && DIRTY_N=$(echo "$DIRTY" | wc -l | tr -d ' ')

    local DRIFT_FILES
    DRIFT_FILES=$(chezmoi $CM_SRC status 2>/dev/null)
    UNAPPLIED=0; [[ -n "$DRIFT_FILES" ]] && UNAPPLIED=$(echo "$DRIFT_FILES" | wc -l | tr -d ' ')

    # sync indicator (ahead/behind origin) — no space before paren
    local SYNC="" VIS_W=${#REPO}
    if (( AHEAD > 0 || BEHIND > 0 )); then
      SYNC="${DIM}(${RST}"
      VIS_W=$(( VIS_W + 1 ))
      if (( AHEAD > 0 )); then
        SYNC="${SYNC}${YLW}↑${AHEAD}${RST}"
        VIS_W=$(( VIS_W + 1 + ${#AHEAD} ))
      fi
      if (( AHEAD > 0 && BEHIND > 0 )); then
        SYNC="${SYNC}${DIM}/${RST}"
        VIS_W=$(( VIS_W + 1 ))
      fi
      if (( BEHIND > 0 )); then
        SYNC="${SYNC}${CYN}↓${BEHIND}${RST}"
        VIS_W=$(( VIS_W + 1 + ${#BEHIND} ))
      fi
      SYNC="${SYNC}${DIM})${RST}"
      VIS_W=$(( VIS_W + 1 ))
    fi

    local COL=22
    local PAD_N=$(( COL - VIS_W ))
    (( PAD_N < 2 )) && PAD_N=2

    S=""
    (( DIRTY_N > 0 ))   && S="${S} ${RED}${DIRTY_N} dirty${RST}"
    if (( UNAPPLIED > 0 )); then
      if (( DIRTY_N == 0 )); then
        S="${S} ${YLW}${UNAPPLIED} edited${RST}"
      else
        S="${S} ${YLW}${UNAPPLIED} drifted${RST}"
      fi
    fi

    # print repo header
    [[ "$REPO" != "public" ]] && echo ""
    if [[ -z "$S" && -z "$SYNC" ]]; then
      printf "  %s%*s${GRN}✓${RST}\n" "$REPO" "$PAD_N" ""
    elif [[ -z "$S" ]]; then
      printf "  %s%b%*s${GRN}✓${RST}\n" "$REPO" "$SYNC" "$PAD_N" ""
    else
      HAS_ISSUES=1
      printf "  %s%b%*s%b\n" "$REPO" "$SYNC" "$PAD_N" "" "${S# }"

      # collect all files with signs
      local -A FILE_SIGNS=()
      if [[ -n "$DIRTY" ]]; then
        while IFS= read -r l; do
          local code="${l:0:2}" file="${l:3}"
          case "$code" in
            "??"|A?|?A) FILE_SIGNS["$file"]="${GRN}+${RST}" ;;
            D?|?D)      FILE_SIGNS["$file"]="${RED}-${RST}" ;;
            R?)         FILE_SIGNS["$file"]="${CYN}→${RST}" ;;
            *)          FILE_SIGNS["$file"]="${YLW}~${RST}" ;;
          esac
        done <<< "$DIRTY"
      fi
      if [[ -n "$DRIFT_FILES" ]]; then
        while IFS= read -r l; do
          local dcode="${l:0:2}" dfile="${l:3}"
          [[ -z "$dfile" ]] && continue
          if [[ -z "${FILE_SIGNS["$dfile"]+x}" ]]; then
            case "$dcode" in
              A*)  FILE_SIGNS["$dfile"]="${GRN}+${RST}" ;;
              D*)  FILE_SIGNS["$dfile"]="${RED}-${RST}" ;;
              *)   FILE_SIGNS["$dfile"]="${YLW}~${RST}" ;;
            esac
          fi
        done <<< "$DRIFT_FILES"
      fi

      for f in $(echo "${!FILE_SIGNS[@]}" | tr ' ' '\n' | sort); do
        printf "  %*s%b ${DIM}%s${RST}\n" "$COL" "" "${FILE_SIGNS[$f]}" "$f"
      done
    fi

    # per-repo actions (git add/commit only)
    local -a REPO_ACTS=()
    (( DIRTY_N > 0 ))   && REPO_ACTS+=("${YLW}git -C ${SHORT_DIR} add -A${RST}")
    (( DIRTY_N > 0 ))   && REPO_ACTS+=("${YLW}git -C ${SHORT_DIR} commit${RST}")

    if [[ "$REPO" == "public" ]]; then
      REPO_ACTS_pub=("${REPO_ACTS[@]}")
    else
      REPO_ACTS_priv=("${REPO_ACTS[@]}")
    fi

    # shared actions (deduplicated across repos)
    (( BEHIND > 0 ))    && HAS_PULL=1
    if (( UNAPPLIED > 0 )); then
      if (( DIRTY_N == 0 )); then
        HAS_READD=1
      else
        HAS_READD=1; HAS_APPLY=1
      fi
    fi
    (( AHEAD > 0 ))     && HAS_PUSH=1
  done

  local ANY_REPO_ACTS=$(( ${#REPO_ACTS_pub[@]} + ${#REPO_ACTS_priv[@]} ))
  local ANY_SHARED=$(( HAS_PULL + HAS_READD + HAS_APPLY + HAS_PUSH ))

  if (( ANY_REPO_ACTS + ANY_SHARED > 0 )); then
    printf "\n${DIM}suggested next steps →${RST}\n\n"
    (( HAS_PULL > 0 ))  && printf "    ${CYN}home pull${RST}\n"
    (( HAS_READD > 0 )) && printf "    ${YLW}home re-add${RST}  ${DIM}# sync edited files from ~${RST}\n"
    (( HAS_APPLY > 0 )) && printf "    ${YLW}home apply${RST}   ${DIM}# apply source to ~${RST}\n"
    if (( ${#REPO_ACTS_pub[@]} > 0 )); then
      for act in "${REPO_ACTS_pub[@]}"; do
        printf "    %b\n" "$act"
      done
    fi
    if (( ${#REPO_ACTS_priv[@]} > 0 )); then
      for act in "${REPO_ACTS_priv[@]}"; do
        printf "    %b\n" "$act"
      done
    fi
    (( HAS_PUSH > 0 ))  && printf "    ${GRN}home push${RST}\n"
  elif (( HAS_ISSUES == 0 )); then
    printf "\n${GRN}all clear${RST}\n"
  fi
  echo ""
}

case "${1:-}" in
  check)   cmd_check ;;
  init)    cmd_init ;;
  re-add)  cmd_readd ;;
  apply)   cmd_apply ;;
  pull)    cmd_pull ;;
  push)    cmd_push ;;
  status)  cmd_status ;;
  diff)    cmd_diff ;;
  managed) cmd_managed ;;
  verify)  cmd_verify ;;
  help|"") cmd_help ;;
  *)       for repo in $(_repos); do _cm "$repo" "$@"; done ;;
esac
