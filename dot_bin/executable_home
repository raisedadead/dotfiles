# File name: home
# Two-repo chezmoi wrapper (public + private)
#-----------------------------------------------------------

set -uo pipefail

PUB="$HOME/.dotfiles"
PRIV="$HOME/.dotfiles-private"

# Colors
DIM=$'\e[0;90m'; GRN=$'\e[0;32m'; RED=$'\e[0;31m'; YLW=$'\e[0;33m'
CYN=$'\e[0;36m'; BLD=$'\e[1m'; RST=$'\e[0m'

p()  { printf "${DIM}dotfiles ·${RST} %s\n" "$1"; }
ok() { printf "${GRN}dotfiles ·${RST} %s\n" "$1"; }

has_priv() { [[ -d "$PRIV" ]]; }

# Run a chezmoi command against both repos
both() {
  chezmoi "$@"
  has_priv && chezmoi --source "$PRIV" "$@"
}

cmd_help() {
  echo ""
  printf "  ${BLD}home check${RST}               ${DIM}show status and suggested actions${RST}\n"
  printf "  ${BLD}home apply${RST}               ${DIM}apply both repos to home dir${RST}\n"
  printf "  ${BLD}home pull${RST}                ${DIM}pull and apply both repos${RST}\n"
  printf "  ${BLD}home push${RST}                ${DIM}push both repos to origin${RST}\n"
  echo ""
  printf "  ${BLD}home status${RST}              ${DIM}show git status for both repos${RST}\n"
  printf "  ${BLD}home diff${RST}                ${DIM}show pending changes in both repos${RST}\n"
  printf "  ${BLD}home managed${RST}             ${DIM}list all managed files${RST}\n"
  printf "  ${BLD}home verify${RST}              ${DIM}check if home dir is in sync${RST}\n"
  echo ""
  printf "  ${BLD}home init${RST}                ${DIM}clone private repo and apply both${RST}\n"
  echo ""
  printf "  ${DIM}Anything else is passed through to chezmoi directly.${RST}\n"
  printf "  ${DIM}e.g. home re-add, home edit, home doctor${RST}\n"
  echo ""
}

cmd_init() {
  echo ""
  if ! has_priv; then
    p "cloning private repo..."
    git clone git@github.com:raisedadead/dotfiles-private.git "$PRIV" || {
      echo ""
      printf "${YLW}dotfiles ·${RST} clone failed — is SSH configured?\n"
      printf "           run ${BLD}home init${RST} after setting up SSH\n"
      exit 1
    }
  else
    p "private repo found"
  fi
  echo ""
  p "applying public repo..."
  chezmoi apply
  p "applying private repo..."
  chezmoi --source "$PRIV" apply
  echo ""
  ok "setup complete"
}

cmd_apply() {
  echo ""
  p "applying public repo..."
  chezmoi apply
  ok "public repo applied"
  if has_priv; then
    echo ""
    p "applying private repo..."
    chezmoi --source "$PRIV" apply
    ok "private repo applied"
  fi
  echo ""
}

cmd_pull() {
  echo ""
  p "pulling public repo..."
  chezmoi update
  ok "public repo updated"
  if has_priv; then
    echo ""
    p "pulling private repo..."
    git -C "$PRIV" pull --rebase
    chezmoi --source "$PRIV" apply
    ok "private repo updated"
  fi
  echo ""
}

cmd_push() {
  local br
  echo ""
  br=$(git -C "$PUB" branch --show-current)
  p "pushing public repo ($br)..."
  git -C "$PUB" push origin "$br"
  ok "public repo pushed"
  if has_priv; then
    echo ""
    br=$(git -C "$PRIV" branch --show-current)
    p "pushing private repo ($br)..."
    git -C "$PRIV" push origin "$br"
    ok "private repo pushed"
  fi
  echo ""
}

cmd_status() {
  echo ""
  printf "${DIM}dotfiles ·${RST} ${BLD}public repo${RST}\n"
  git -C "$PUB" status --short
  if has_priv; then
    echo ""
    printf "${DIM}dotfiles ·${RST} ${BLD}private repo${RST}\n"
    git -C "$PRIV" status --short
  fi
  echo ""
}

cmd_diff()    { both diff; }
cmd_managed() { both managed; }

cmd_verify() {
  echo ""
  printf "  ${BLD}public repo${RST}   "
  if chezmoi verify 2>/dev/null; then
    printf "${GRN}in sync${RST}\n"
  else
    printf "${YLW}drift detected${RST} — run ${BLD}home diff${RST}\n"
  fi
  if has_priv; then
    printf "  ${BLD}private repo${RST}  "
    if chezmoi --source "$PRIV" verify 2>/dev/null; then
      printf "${GRN}in sync${RST}\n"
    else
      printf "${YLW}drift detected${RST} — run ${BLD}home diff${RST}\n"
    fi
  fi
  echo ""
}

cmd_check() {
  local PUB_N PRIV_N
  PUB_N=$(chezmoi managed 2>/dev/null | wc -l | tr -d ' ')
  PRIV_N=$(chezmoi --source "$PRIV" managed 2>/dev/null | wc -l | tr -d ' ')
  echo ""
  printf "${BLD}dotfiles${RST} ${DIM}· %s public · %s private${RST}\n\n" "$PUB_N" "$PRIV_N"

  git -C "$PUB" fetch --quiet 2>/dev/null &
  has_priv && git -C "$PRIV" fetch --quiet 2>/dev/null &
  wait

  local HAS_ISSUES=0 HAS_PULL=0 HAS_APPLY=0 HAS_PUSH=0
  local DIR CM_SRC AHEAD BEHIND BR DIRTY DIRTY_N UNAPPLIED S SHORT_DIR

  # collect per-repo status + actions
  declare -a REPO_ACTS_pub=() REPO_ACTS_priv=()

  for REPO in public private; do
    if [[ "$REPO" == "public" ]]; then
      DIR="$PUB"; CM_SRC=""
    else
      DIR="$PRIV"; CM_SRC="--source $PRIV"
      if [[ ! -d "$DIR" ]]; then
        printf "  ${DIM}%-10s not cloned${RST}\n" "$REPO"
        continue
      fi
    fi

    SHORT_DIR="${DIR/#$HOME/\~}"
    AHEAD=0; BEHIND=0
    BR=$(git -C "$DIR" branch --show-current 2>/dev/null)
    if git -C "$DIR" rev-parse --verify "origin/$BR" &>/dev/null; then
      read -r BEHIND AHEAD < <(git -C "$DIR" rev-list --left-right --count "origin/$BR...HEAD" 2>/dev/null)
    fi

    DIRTY=$(git -C "$DIR" status --porcelain 2>/dev/null)
    DIRTY_N=0; [[ -n "$DIRTY" ]] && DIRTY_N=$(echo "$DIRTY" | wc -l | tr -d ' ')

    UNAPPLIED=$(chezmoi $CM_SRC diff --no-pager 2>&1 | grep -c '^diff' || true)

    S=""
    (( BEHIND > 0 ))    && S="${S} ${CYN}${BEHIND} behind${RST}"
    (( AHEAD > 0 ))     && S="${S} ${YLW}${AHEAD} ahead${RST}"
    (( DIRTY_N > 0 ))   && S="${S} ${RED}${DIRTY_N} dirty${RST}"
    (( UNAPPLIED > 0 )) && S="${S} ${YLW}${UNAPPLIED} unapplied${RST}"

    if [[ -z "$S" ]]; then
      printf "  %-10s ${GRN}✓${RST}\n" "$REPO"
    else
      HAS_ISSUES=1
      printf "  %-10s%s\n" "$REPO" "$S"
      if [[ -n "$DIRTY" ]]; then
        echo "$DIRTY" | while IFS= read -r l; do
          printf "  ${DIM}           %s${RST}\n" "$l"
        done
      fi
    fi

    # per-repo actions (git add/commit only)
    local -a REPO_ACTS=()
    (( DIRTY_N > 0 ))   && REPO_ACTS+=("${YLW}git -C ${SHORT_DIR} add -A${RST}")
    (( DIRTY_N > 0 ))   && REPO_ACTS+=("${YLW}git -C ${SHORT_DIR} commit${RST}")

    if [[ "$REPO" == "public" ]]; then
      REPO_ACTS_pub=("${REPO_ACTS[@]}")
    else
      REPO_ACTS_priv=("${REPO_ACTS[@]}")
    fi

    # shared actions (deduplicated across repos)
    (( BEHIND > 0 ))    && HAS_PULL=1
    (( UNAPPLIED > 0 )) && HAS_APPLY=1
    (( AHEAD > 0 ))     && HAS_PUSH=1
  done

  local ANY_REPO_ACTS=$(( ${#REPO_ACTS_pub[@]} + ${#REPO_ACTS_priv[@]} ))
  local ANY_SHARED=$(( HAS_PULL + HAS_APPLY + HAS_PUSH ))

  if (( ANY_REPO_ACTS + ANY_SHARED > 0 )); then
    printf "\n${DIM}suggested next steps →${RST}\n"
    if (( ${#REPO_ACTS_pub[@]} > 0 )); then
      printf "\n  ${BLD}public${RST}\n"
      for act in "${REPO_ACTS_pub[@]}"; do
        printf "    %b\n" "$act"
      done
    fi
    if (( ${#REPO_ACTS_priv[@]} > 0 )); then
      printf "\n  ${BLD}private${RST}\n"
      for act in "${REPO_ACTS_priv[@]}"; do
        printf "    %b\n" "$act"
      done
    fi
    if (( ANY_SHARED > 0 )); then
      printf "\n  ${BLD}then${RST}\n"
      (( HAS_PULL > 0 ))  && printf "    ${CYN}home pull${RST}\n"
      (( HAS_APPLY > 0 )) && printf "    ${YLW}home apply${RST}\n"
      (( HAS_PUSH > 0 ))  && printf "    ${GRN}home push${RST}\n"
    fi
  elif (( HAS_ISSUES == 0 )); then
    printf "\n${GRN}all clear${RST}\n"
  fi
  echo ""
}

case "${1:-}" in
  check)   cmd_check ;;
  init)    cmd_init ;;
  apply)   cmd_apply ;;
  pull)    cmd_pull ;;
  push)    cmd_push ;;
  status)  cmd_status ;;
  diff)    cmd_diff ;;
  managed) cmd_managed ;;
  verify)  cmd_verify ;;
  help|"") cmd_help ;;
  *)       chezmoi "$@" ;;
esac
