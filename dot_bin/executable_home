set -uo pipefail

PUB="$HOME/.dotfiles"
PRIV="$HOME/.dotfiles-private"

# Colors
DIM=$'\e[0;90m'; GRN=$'\e[0;32m'; RED=$'\e[0;31m'; YLW=$'\e[0;33m'
CYN=$'\e[0;36m'; BLD=$'\e[1m'; RST=$'\e[0m'

p()  { printf "${DIM}dotfiles ·${RST} %s\n" "$1"; }
ok() { printf "${GRN}dotfiles ·${RST} %s\n" "$1"; }

has_priv() { [[ -d "$PRIV" ]]; }

# Run chezmoi for a named repo (public|private)
_cm() {
  local repo="$1"; shift
  if [[ "$repo" == "private" ]]; then
    chezmoi --source "$PRIV" "$@" 2> >(grep -v 'config file template' >&2)
  else
    chezmoi "$@"
  fi
}

# List repos to operate on based on REPO_SEL
_repos() {
  case "${REPO_SEL:-}" in
    public)  echo "public" ;;
    private) echo "private" ;;
    *)       echo "public"; has_priv && echo "private" ;;
  esac
}

# Parse optional repo selector: home [public|private] <command>
REPO_SEL=""
case "${1:-}" in
  public|pub)   REPO_SEL="public"; shift ;;
  private|prv)  REPO_SEL="private"; shift ;;
esac

cmd_help() {
  echo ""
  printf "  ${BLD}Custom commands (both repos):${RST}\n\n"
  printf "  ${BLD}home check${RST}               ${DIM}show status and suggested actions${RST}\n"
  printf "  ${BLD}home sync${RST}                ${DIM}auto-resolve drift + stage for commit${RST}\n"
  printf "  ${BLD}home apply${RST}               ${DIM}→ deploy source to ~${RST}\n"
  printf "  ${BLD}home re-add${RST}              ${DIM}← capture ~ edits back to source${RST}\n"
  printf "  ${BLD}home init${RST}                ${DIM}clone private repo and apply both${RST}\n"
  printf "  ${BLD}home cd${RST}                  ${DIM}cd to public source dir${RST}\n"
  echo ""
  printf "  ${BLD}Chezmoi passthrough (requires pub/prv):${RST}\n\n"
  printf "  ${DIM}home ${RST}${BLD}pub${RST}${DIM}|${RST}${BLD}prv${RST} ${DIM}<command>${RST}     ${DIM}runs chezmoi with the correct --source${RST}\n"
  printf "  ${DIM}e.g. home pub edit, home prv diff, home pub managed${RST}\n"
  echo ""
}

cmd_init() {
  echo ""
  if ! has_priv; then
    p "cloning private repo..."
    git clone git@github.com:raisedadead/dotfiles-private.git "$PRIV" || {
      echo ""
      printf "${YLW}dotfiles ·${RST} clone failed — is SSH configured?\n"
      printf "           run ${BLD}home init${RST} after setting up SSH\n"
      exit 1
    }
  else
    p "private repo found"
  fi
  echo ""
  p "regenerating config..."
  chezmoi init
  p "applying public repo..."
  chezmoi apply
  p "applying private repo..."
  _cm private apply
  echo ""
  ok "setup complete"
}

cmd_readd() {
  echo ""
  local first=1 failed=0
  for repo in $(_repos); do
    (( first )) || echo ""
    first=0
    p "re-adding $repo repo..."
    if _cm "$repo" re-add; then
      ok "$repo repo re-added"
    else
      printf "${RED}dotfiles ·${RST} $repo re-add failed\n"
      failed=1; break
    fi
  done
  echo ""
  if (( failed )); then
    printf "${YLW}dotfiles ·${RST} run ${BLD}home check${RST} to see what went wrong\n"
  else
    printf "${DIM}dotfiles ·${RST} run ${BLD}home check${RST} for next steps\n"
  fi
  echo ""
}

cmd_apply() {
  echo ""
  local first=1 failed=0
  for repo in $(_repos); do
    (( first )) || echo ""
    first=0
    p "applying $repo repo..."
    if _cm "$repo" apply; then
      ok "$repo repo applied"
    else
      printf "${RED}dotfiles ·${RST} $repo apply failed\n"
      failed=1; break
    fi
  done
  echo ""
  if (( failed )); then
    printf "${YLW}dotfiles ·${RST} run ${BLD}home check${RST} to see what went wrong\n"
  else
    printf "${DIM}dotfiles ·${RST} run ${BLD}home check${RST} for next steps\n"
  fi
  echo ""
}

cmd_check() {
  local PUB_N PRIV_N
  PUB_N=$(chezmoi managed 2>/dev/null | wc -l | tr -d ' ')
  PRIV_N=$(chezmoi --source "$PRIV" managed 2>/dev/null | wc -l | tr -d ' ')
  echo ""
  printf "${BLD}dotfiles${RST} ${DIM}· %s public · %s private${RST}\n\n" "$PUB_N" "$PRIV_N"

  git -C "$PUB" fetch --quiet 2>/dev/null &
  has_priv && git -C "$PRIV" fetch --quiet 2>/dev/null &
  wait

  local HAS_ISSUES=0 HAS_CONFLICT=0 HAS_RESOLVABLE=0
  local DIR CM_SRC AHEAD BEHIND BR DIRTY DIRTY_N TRACKED_DIRTY_N UNAPPLIED S SHORT_DIR
  local NEEDS_COMMIT_pub=0 NEEDS_COMMIT_priv=0
  local AHEAD_pub=0 AHEAD_priv=0 BEHIND_pub=0 BEHIND_priv=0
  local CONFLICT_pub=0 CONFLICT_priv=0

  for REPO in public private; do
    if [[ "$REPO" == "public" ]]; then
      DIR="$PUB"; CM_SRC=""
    else
      DIR="$PRIV"; CM_SRC="--source $PRIV"
      if [[ ! -d "$DIR" ]]; then
        printf "  ${DIM}%-10s not cloned${RST}\n" "$REPO"
        continue
      fi
    fi

    SHORT_DIR="${DIR/#$HOME/\~}"
    AHEAD=0; BEHIND=0
    BR=$(git -C "$DIR" branch --show-current 2>/dev/null)
    if git -C "$DIR" rev-parse --verify "origin/$BR" &>/dev/null; then
      read -r BEHIND AHEAD < <(git -C "$DIR" rev-list --left-right --count "origin/$BR...HEAD" 2>/dev/null)
    fi

    DIRTY=$(git -C "$DIR" status --porcelain 2>/dev/null)
    DIRTY_N=0; [[ -n "$DIRTY" ]] && DIRTY_N=$(echo "$DIRTY" | wc -l | tr -d ' ')
    TRACKED_DIRTY_N=0; [[ -n "$DIRTY" ]] && TRACKED_DIRTY_N=$(echo "$DIRTY" | grep -v '^??' | wc -l | tr -d ' ')

    local DRIFT_FILES
    DRIFT_FILES=$(chezmoi $CM_SRC status 2>/dev/null)
    UNAPPLIED=0; [[ -n "$DRIFT_FILES" ]] && UNAPPLIED=$(echo "$DRIFT_FILES" | wc -l | tr -d ' ')

    # sync indicator (ahead/behind origin) — no space before paren
    local SYNC="" VIS_W=${#REPO}
    if (( AHEAD > 0 || BEHIND > 0 )); then
      SYNC="${DIM}(${RST}"
      VIS_W=$(( VIS_W + 1 ))
      if (( AHEAD > 0 )); then
        SYNC="${SYNC}${YLW}↑${AHEAD}${RST}"
        VIS_W=$(( VIS_W + 1 + ${#AHEAD} ))
      fi
      if (( AHEAD > 0 && BEHIND > 0 )); then
        SYNC="${SYNC}${DIM}/${RST}"
        VIS_W=$(( VIS_W + 1 ))
      fi
      if (( BEHIND > 0 )); then
        SYNC="${SYNC}${CYN}↓${BEHIND}${RST}"
        VIS_W=$(( VIS_W + 1 + ${#BEHIND} ))
      fi
      SYNC="${SYNC}${DIM})${RST}"
      VIS_W=$(( VIS_W + 1 ))
    fi

    local COL=22
    local PAD_N=$(( COL - VIS_W ))
    (( PAD_N < 2 )) && PAD_N=2

    S=""
    (( DIRTY_N > 0 ))   && S="${S} ${RED}→ ${DIRTY_N} source dirty${RST}"
    if (( UNAPPLIED > 0 )); then
      if (( TRACKED_DIRTY_N == 0 )); then
        S="${S} ${YLW}← ${UNAPPLIED} edited in ~${RST}"
      else
        S="${S} ${YLW}⇄ ${UNAPPLIED} drifted${RST}"
      fi
    fi

    # print repo header
    [[ "$REPO" != "public" ]] && echo ""
    if [[ -z "$S" && -z "$SYNC" ]]; then
      printf "  %s%*s${GRN}✓${RST}\n" "$REPO" "$PAD_N" ""
    elif [[ -z "$S" ]]; then
      printf "  %s%b%*s${GRN}✓${RST}\n" "$REPO" "$SYNC" "$PAD_N" ""
    else
      HAS_ISSUES=1
      printf "  %s%b%*s%b\n" "$REPO" "$SYNC" "$PAD_N" "" "${S# }"

      # collect all files with signs
      local -A FILE_SIGNS=()
      if [[ -n "$DIRTY" ]]; then
        while IFS= read -r l; do
          local code="${l:0:2}" file="${l:3}"
          case "$code" in
            "??"|A?|?A) FILE_SIGNS["$file"]="${GRN}+${RST}" ;;
            D?|?D)      FILE_SIGNS["$file"]="${RED}-${RST}" ;;
            R?)         FILE_SIGNS["$file"]="${CYN}→${RST}" ;;
            *)          FILE_SIGNS["$file"]="${YLW}~${RST}" ;;
          esac
        done <<< "$DIRTY"
      fi
      if [[ -n "$DRIFT_FILES" ]]; then
        while IFS= read -r l; do
          local dcode="${l:0:2}" dfile="${l:3}"
          [[ -z "$dfile" ]] && continue
          if [[ -z "${FILE_SIGNS["$dfile"]+x}" ]]; then
            case "$dcode" in
              A*)  FILE_SIGNS["$dfile"]="${GRN}+${RST}" ;;
              D*)  FILE_SIGNS["$dfile"]="${RED}-${RST}" ;;
              *)   FILE_SIGNS["$dfile"]="${YLW}~${RST}" ;;
            esac
          fi
        done <<< "$DRIFT_FILES"
      fi

      readarray -t _sorted < <(printf '%s\n' "${!FILE_SIGNS[@]}" | sort)
      for f in "${_sorted[@]}"; do
        printf "  %*s%b ${DIM}%s${RST}\n" "$COL" "" "${FILE_SIGNS[$f]}" "$f"
      done
    fi

    if [[ "$REPO" == "public" ]]; then
      (( DIRTY_N > 0 || UNAPPLIED > 0 )) && NEEDS_COMMIT_pub=1
      AHEAD_pub=$AHEAD; BEHIND_pub=$BEHIND
    else
      (( DIRTY_N > 0 || UNAPPLIED > 0 )) && NEEDS_COMMIT_priv=1
      AHEAD_priv=$AHEAD; BEHIND_priv=$BEHIND
    fi

    if (( TRACKED_DIRTY_N > 0 && UNAPPLIED > 0 )); then
      HAS_CONFLICT=1
      [[ "$REPO" == "public" ]] && CONFLICT_pub=1 || CONFLICT_priv=1
    elif (( DIRTY_N > 0 || UNAPPLIED > 0 )); then
      HAS_RESOLVABLE=1
    fi
  done

  local HAS_PULL=$(( (BEHIND_pub > 0) + (BEHIND_priv > 0) ))
  local HAS_PUSH=$(( (AHEAD_pub > 0) + (AHEAD_priv > 0) ))
  local ANY_WORK=$(( NEEDS_COMMIT_pub + NEEDS_COMMIT_priv ))
  local ANY_SHARED=$(( HAS_PULL + HAS_CONFLICT + HAS_RESOLVABLE + HAS_PUSH ))

  if (( ANY_WORK + ANY_SHARED > 0 )); then
    printf "\n${DIM}next →${RST}\n\n"
    (( BEHIND_pub > 0 ))  && printf "    ${CYN}git -C ~/.dotfiles pull${RST}\n"
    (( BEHIND_priv > 0 )) && printf "    ${CYN}git -C ~/.dotfiles-private pull${RST}\n"
    (( HAS_RESOLVABLE || HAS_CONFLICT )) && printf "    ${YLW}home sync${RST}\n"
    (( CONFLICT_pub ))  && printf "    ${RED}home pub diff${RST}\n"
    (( CONFLICT_priv )) && printf "    ${RED}home prv diff${RST}\n"
    local WILL_COMMIT_pub=$(( NEEDS_COMMIT_pub ))
    local WILL_COMMIT_priv=$(( NEEDS_COMMIT_priv ))
    (( WILL_COMMIT_pub ))  && printf "    ${YLW}git -C ~/.dotfiles commit${RST}\n"
    (( WILL_COMMIT_priv )) && printf "    ${YLW}git -C ~/.dotfiles-private commit${RST}\n"
    (( WILL_COMMIT_pub || AHEAD_pub > 0 ))  && printf "    ${GRN}git -C ~/.dotfiles push${RST}\n"
    (( WILL_COMMIT_priv || AHEAD_priv > 0 )) && printf "    ${GRN}git -C ~/.dotfiles-private push${RST}\n"
  elif (( HAS_ISSUES == 0 )); then
    printf "\n${GRN}all clear${RST}\n"
  fi
  echo ""
}

cmd_sync() {
  echo ""
  local had_conflict=0 had_action=0

  for repo in $(_repos); do
    local dir
    if [[ "$repo" == "public" ]]; then
      dir="$PUB"
    else
      dir="$PRIV"
      [[ ! -d "$dir" ]] && continue
    fi

    local dirty drift dirty_n tracked_dirty_n drift_n
    dirty=$(git -C "$dir" status --porcelain 2>/dev/null)
    dirty_n=0; [[ -n "$dirty" ]] && dirty_n=$(echo "$dirty" | wc -l | tr -d ' ')
    tracked_dirty_n=0; [[ -n "$dirty" ]] && tracked_dirty_n=$(echo "$dirty" | grep -v '^??' | wc -l | tr -d ' ')
    drift=$(_cm "$repo" status 2>/dev/null)
    drift_n=0; [[ -n "$drift" ]] && drift_n=$(echo "$drift" | wc -l | tr -d ' ')

    if (( tracked_dirty_n > 0 && drift_n > 0 )); then
      local prefix; [[ "$repo" == "public" ]] && prefix="pub" || prefix="prv"
      printf "  ${RED}⇄ $repo${RST}: %d source dirty + %d target edited — run ${BLD}home %s diff${RST} to review\n" "$tracked_dirty_n" "$drift_n" "$prefix"
      had_conflict=1
    elif (( drift_n > 0 )); then
      p "← $repo: re-adding $drift_n file(s) from ~ to source..."
      if ! _cm "$repo" re-add; then
        printf "  ${RED}$repo${RST}: re-add failed\n"
        had_conflict=1
        continue
      fi
      git -C "$dir" add -u
      ok "← $repo: re-added and staged"
      had_action=1
    elif (( dirty_n > 0 )); then
      p "→ $repo: staging $dirty_n source change(s)..."
      git -C "$dir" add -u
      ok "→ $repo: staged for commit"
      had_action=1
    else
      ok "$repo: in sync"
    fi
  done

  echo ""
  if (( had_conflict )); then
    printf "${YLW}dotfiles ·${RST} run ${BLD}home check${RST} to see what needs resolving\n"
  elif (( had_action )); then
    printf "${DIM}dotfiles ·${RST} run ${BLD}home check${RST} for next steps\n"
  fi
  echo ""
}

# Passthrough requires explicit repo selector
cmd_passthrough() {
  if [[ -z "${REPO_SEL:-}" ]]; then
    printf "${RED}dotfiles ·${RST} chezmoi commands require a repo selector\n"
    printf "  ${DIM}e.g. home ${RST}${BLD}pub${RST} %s${DIM}, home ${RST}${BLD}prv${RST} %s\n" "$1" "$1"
    exit 1
  fi
  _cm "$REPO_SEL" "$@"
}

case "${1:-}" in
  check)   cmd_check ;;
  sync)    cmd_sync ;;
  init)    cmd_init ;;
  apply)   cmd_apply ;;
  re-add)  cmd_readd ;;
  cd)
    if [[ "${REPO_SEL:-}" == "private" ]]; then
      printf '%s\n' "$PRIV"
    else
      printf '%s\n' "$PUB"
    fi
    ;;
  help|"") cmd_help ;;
  *)       cmd_passthrough "$@" ;;
esac
