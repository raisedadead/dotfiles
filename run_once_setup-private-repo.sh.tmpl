#!/bin/bash
# Clones the private dotfiles repo.
# chezmoi runs this once on first apply (tracked by content hash).
# NOTE: Does not call chezmoi apply — that would deadlock (nested chezmoi).
# Run `chezmoi --source ~/.dotfiles-private apply` separately after.

set -euo pipefail

PRIVATE_REPO="git@github.com:raisedadead/dotfiles-private.git"
PRIVATE_DIR="{{ .chezmoi.homeDir }}/.dotfiles-private"

if [ -d "$PRIVATE_DIR" ]; then
  echo "[dotfiles] Private repo already cloned at $PRIVATE_DIR"
  exit 0
fi

echo "[dotfiles] Cloning private repo..."
if git clone "$PRIVATE_REPO" "$PRIVATE_DIR" 2>/dev/null; then
  echo "[dotfiles] Private repo cloned."
  echo "[dotfiles] Run: chezmoi --source ~/.dotfiles-private apply"
else
  echo "[dotfiles] WARNING: Could not clone private repo (SSH may not be ready)."
  echo "[dotfiles] Run manually later:"
  echo "[dotfiles]   git clone $PRIVATE_REPO $PRIVATE_DIR"
  echo "[dotfiles]   chezmoi --source $PRIVATE_DIR apply"
fi
