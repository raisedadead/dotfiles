# Application Behavior
quit-after-last-window-closed = true

# Notifications
notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 5s

# Shell Integration
shell-integration-features = cursor,sudo

# Quick Terminal
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-position = center
quick-terminal-size = 50%,50%
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.1

# Clipboard
clipboard-read = allow
copy-on-select = false

# Window & Display
window-save-state = always
window-theme = system
window-padding-balance = true
window-padding-x = 15
window-padding-y = 10,0
window-padding-color = extend
window-width = 166
window-height = 54

# Appearance & Transparency
background-opacity = 0.8
background-blur = 15
theme = Catppuccin Mocha
bold-is-bright = true
faint-opacity=1

# Mouse & Selection
focus-follows-mouse = true
mouse-hide-while-typing = true
mouse-scroll-multiplier = precision:0.5,discrete:3

# Typography
font-family = "Berkeley Mono"
font-thicken = true
font-size = 14
font-feature = calt
font-feature = ss01
font-feature = zero
font-codepoint-map = U+E000-U+F8FF=Symbols Nerd Font
font-codepoint-map = U+F0000-U+FFFFF=Symbols Nerd Font

# Shaders
custom-shader = shaders/cursor_warp.glsl

# Cursor
cursor-color = f5e0dc
cursor-text = 11111b
cursor-click-to-move = true

# macOS Specific
macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = left

# Keybindings
keybind = shift+enter=text:\n
keybind = ctrl+enter=text:\r

# Scrollback
keybind = ctrl+shift+j=scroll_page_lines:5
keybind = ctrl+shift+k=scroll_page_lines:-5
keybind = ctrl+shift+h=scroll_to_top
keybind = ctrl+shift+l=scroll_to_bottom

# Scrollback & screen export
keybind = cmd+shift+s=write_scrollback_file:paste
keybind = cmd+shift+c=copy_url_to_clipboard

